---
const footerNavs = [
  {
    title: "Ministry",
    items: [
      { text: "About Us", href: "/about-us" },
      { text: "Watch Live", href: "/watch-live" },
      { text: "Sermons", href: "/sermons" },
      { text: "Contact", href: "/contact" },
    ],
  },
  {
    title: "Connect",
    items: [
      { text: "Prayer Request", href: "/contact#prayer" },
      { text: "Facebook", href: "https://www.facebook.com/p/Outreach-For-The-Unreached-Soul-Winning-Ministry-100080165448656/", external: true },
      { text: "YouTube", href: "https://www.youtube.com/@pastorreginalddublin3943/videos", external: true },
    ],
  },
];

const socialLinks = [
  {
    name: "Facebook",
    href: "https://www.facebook.com/p/Outreach-For-The-Unreached-Soul-Winning-Ministry-100080165448656/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
  {
    name: "YouTube",
    href: "https://www.youtube.com/@pastorreginalddublin3943/videos",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white pt-16 pb-8">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">

      <!-- Ministry Info -->
      <div class="lg:col-span-2">
        <a href="/" class="text-xl font-bold text-white font-serif inline-flex items-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512" class="h-10 w-auto text-white mr-2">
            <path fill="currentColor" d="M344 24c0-13.3-10.7-24-24-24s-24 10.7-24 24l0 24-32 0c-13.3 0-24 10.7-24 24s10.7 24 24 24l32 0 0 46.4L183.3 210c-14.5 8.7-23.3 24.3-23.3 41.2L160 512l96 0 0-96c0-35.3 28.7-64 64-64s64 28.7 64 64l0 96 96 0 0-260.8c0-16.9-8.8-32.5-23.3-41.2L344 142.4 344 96l32 0c13.3 0 24-10.7 24-24s-10.7-24-24-24l-32 0 0-24zM24.9 330.3C9.5 338.8 0 354.9 0 372.4L0 464c0 26.5 21.5 48 48 48l80 0 0-238.4L24.9 330.3zM592 512c26.5 0 48-21.5 48-48l0-91.6c0-17.5-9.5-33.6-24.9-42.1L512 273.6 512 512l80 0z"/>
          </svg>
          Outreach Ministry
        </a>

        <p class="text-gray-300 text-sm mb-6 max-w-sm leading-relaxed">
          Reaching the unreached worldwide through the power of the Gospel — live every Sunday and Tuesday on Facebook and YouTube.
        </p>

        <div class="text-gray-300 text-sm mb-6 space-y-2">
          <p class="leading-relaxed">
            We are an <span class="text-white font-medium">online-only ministry</span> — join us on Facebook and YouTube. No physical campus; worship with us from anywhere.
          </p>
          <p>
            <a href="tel:+18607050042" class="hover:text-primary-300 transition-colors">
              (860) 705-0042
            </a>
          </p>
        </div>

        <div class="text-gray-300 text-sm mb-6 space-y-1">
          <p><span class="text-white font-semibold">Sunday Service</span> — Live on Facebook &amp; YouTube</p>
          <p><span class="text-white font-semibold">Tuesday Bible Study</span> — 6:30 PM, Live on Facebook</p>
        </div>

        <div class="flex space-x-4">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 hover:text-white transition-colors"
                aria-label={link.name}
              >
                <Fragment set:html={link.icon} />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Navigation Groups -->
      {
        footerNavs.map((group) => (
          <div>
            <h4 class="text-lg font-bold mb-4 text-white">{group.title}</h4>
            <ul class="space-y-2">
              {group.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    target={item.external ? "_blank" : undefined}
                    rel={item.external ? "noopener noreferrer" : undefined}
                    class="text-gray-300 hover:text-primary-300 transition-colors text-sm"
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Copyright -->
    <div class="pt-8 mt-8 border-t border-gray-800 text-center text-gray-400 text-sm">
      <p>&copy; {currentYear} Outreach for the Unreached Soul Winning Ministry. All rights reserved.</p>
      <p class="mt-2 text-gray-500 text-xs">
        Website by <a href="https://shorelinewebsolutions.com" target="_blank" rel="noopener noreferrer" class="hover:text-primary-300 transition-colors">Shoreline Web Solutions</a>
      </p>
    </div>
  </div>
</footer>