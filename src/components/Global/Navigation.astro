---
// Define the navigation items
const navItems = [
  { text: "Home", href: "/" },
  { text: "About Us", href: "/about-us" },
  { text: "Watch Live", href: "/watch-live" },
  { text: "Sermons", href: "/sermons" },
  { text: "Contact", href: "/contact" },
];

// Match nav href without false positives (e.g. /sermons vs /sermonsomething)
const rawPath = Astro.url.pathname.replace(/\/$/, "") || "/";

function isNavActive(href: string): boolean {
  const h = href.replace(/\/$/, "") || "/";
  if (h === "/") return rawPath === "/";
  return rawPath === h || rawPath.startsWith(`${h}/`);
}
---

<!-- Desktop Navigation -->
<nav class="hidden lg:block">
  <ul class="flex items-center space-x-6">
    {
      navItems.map((item) => {
        const isActive = isNavActive(item.href);

        return (
          <li>
            <a
              href={item.href}
              class={`text-base font-medium text-gray-900 transition-colors hover:text-primary-600 ${
                isActive ? "font-semibold" : ""
              }`}
              aria-current={isActive ? "page" : undefined}
            >
              {item.text}
            </a>
          </li>
        );
      })
    }

    <li>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-md hover:bg-primary-700 transition-colors"
      >
        Prayer Request
      </a>
    </li>
  </ul>
</nav>

<!-- Mobile Menu Button (bars → X via aria-expanded + CSS) -->
<button
  type="button"
  id="mobile-menu-button"
  class="relative flex h-10 w-10 items-center justify-center text-gray-700 transition-colors hover:text-primary-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 lg:hidden"
  aria-label="Open menu"
  aria-expanded="false"
  aria-controls="mobile-menu"
>
  <span class="flex h-5 w-6 flex-col justify-between" aria-hidden="true">
    <span class="hamburger-bar"></span>
    <span class="hamburger-bar"></span>
    <span class="hamburger-bar"></span>
  </span>
</button>

<!-- Mobile menu: data-open drives Tailwind variants -->
<div
  id="mobile-menu"
  data-open="false"
  class="pointer-events-none absolute top-full left-0 right-0 z-50 origin-top border-t border-gray-100 bg-white shadow-lg transition-transform duration-200 ease-out lg:hidden scale-y-0 data-[open=true]:pointer-events-auto data-[open=true]:scale-y-100"
  role="menu"
  aria-labelledby="mobile-menu-button"
>
  <div class="px-4 py-6">
    <div class="grid grid-cols-2 gap-3">
      {
        navItems.map((item) => {
          const isActive = isNavActive(item.href);

          return (
            <a
              href={item.href}
              class={`block rounded-lg border border-transparent px-4 py-3 text-center text-sm font-medium text-gray-900 transition-colors hover:bg-gray-50 hover:text-primary-600 ${
                isActive ? "font-semibold" : ""
              }`}
              role="menuitem"
              aria-current={isActive ? "page" : undefined}
            >
              {item.text}
            </a>
          );
        })
      }
    </div>

    <div class="mt-4 pt-4 border-t border-gray-100">
      <a
        href="/contact"
        class="flex items-center justify-center px-4 py-3 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors"
        role="menuitem"
      >
        Submit a Prayer Request
      </a>
    </div>
  </div>
</div>

<style>
  .hamburger-bar {
    display: block;
    height: 2px;
    width: 100%;
    border-radius: 9999px;
    background: currentColor;
    transform-origin: center;
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s ease;
  }

  #mobile-menu-button[aria-expanded="true"] .hamburger-bar:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }

  #mobile-menu-button[aria-expanded="true"] .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  #mobile-menu-button[aria-expanded="true"] .hamburger-bar:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  #mobile-menu a {
    transition: all 0.15s ease;
  }
</style>

<script is:inline>
  (function () {
    function initMobileNav() {
      var btn = document.getElementById("mobile-menu-button");
      var menu = document.getElementById("mobile-menu");
      if (!btn || !menu) return;

      var open = false;

      function setOpen(next) {
        open = next;
        menu.setAttribute("data-open", open ? "true" : "false");
        btn.setAttribute("aria-expanded", open ? "true" : "false");
        btn.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      }

      function toggle() {
        setOpen(!open);
      }

      btn.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        toggle();
      });

      document.addEventListener("click", function (e) {
        if (
          open &&
          !menu.contains(/** @type {Node} */ (e.target)) &&
          !btn.contains(/** @type {Node} */ (e.target))
        ) {
          setOpen(false);
        }
      });

      menu.querySelectorAll('a[href^="/"]').forEach(function (link) {
        link.addEventListener("click", function () {
          if (open) setTimeout(function () { setOpen(false); }, 100);
        });
      });

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" && open) setOpen(false);
      });

      window.addEventListener("resize", function () {
        if (window.innerWidth >= 1024 && open) setOpen(false);
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initMobileNav);
    } else {
      initMobileNav();
    }
  })();
</script>
