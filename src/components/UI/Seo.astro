---
export interface Props {
  title?: string;
  description?: string;
  image?: {
    url: string;
    alt: string;
  };
  type?: "website" | "article";
  canonicalUrl?: string;
}

const {
  title = "Outreach for the Unreached Soul Winning Ministry | Online Church",
  description = "An online Spirit-filled ministry reaching souls worldwide through live worship and the Word. Join us on Facebook and YouTube.",
  image = {
    url: "/uploads/hero-bg.webp",
    alt: "Outreach for the Unreached Soul Winning Ministry",
  },
  type = "website",
  canonicalUrl,
} = Astro.props;

const canonicalURL = canonicalUrl || new URL(Astro.url.pathname, Astro.site);
const siteUrl = "https://outreach-for-the-unreached-soul-winning-ministry.pages.dev";
const imageUrl = new URL(image.url, Astro.site).toString();
const canonicalStr = canonicalURL.toString();

const churchSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Church",
  "@id": siteUrl,
  "name": "Outreach for the Unreached Soul Winning Ministry",
  "description": "An online Spirit-filled ministry reaching souls worldwide through live worship and the Word of God.",
  "url": siteUrl,
  "sameAs": [
    "https://www.facebook.com/p/Outreach-For-The-Unreached-Soul-Winning-Ministry-100080165448656/",
    "https://www.youtube.com/@pastorreginalddublin3943/videos"
  ],
  "event": [
    {
      "@type": "Event",
      "name": "Sunday Worship Service",
      "description": "Live Sunday worship service streamed on Facebook and YouTube.",
      "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
      "eventStatus": "https://schema.org/EventScheduled",
      "location": {
        "@type": "VirtualLocation",
        "url": "https://www.facebook.com/p/Outreach-For-The-Unreached-Soul-Winning-Ministry-100080165448656/"
      },
      "organizer": {
        "@type": "Organization",
        "name": "Outreach for the Unreached Soul Winning Ministry",
        "url": siteUrl
      }
    },
    {
      "@type": "Event",
      "name": "Tuesday Bible Study",
      "description": "Weekly Bible study streamed live every Tuesday at 6:30 PM.",
      "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
      "eventStatus": "https://schema.org/EventScheduled",
      "location": {
        "@type": "VirtualLocation",
        "url": "https://www.facebook.com/p/Outreach-For-The-Unreached-Soul-Winning-Ministry-100080165448656/"
      },
      "organizer": {
        "@type": "Organization",
        "name": "Outreach for the Unreached Soul Winning Ministry",
        "url": siteUrl
      }
    }
  ]
});

const pastorSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Reginald Dublin",
  "jobTitle": "Pastor",
  "worksFor": {
    "@type": "Church",
    "@id": siteUrl
  },
  "sameAs": [
    "https://www.facebook.com/p/Outreach-For-The-Unreached-Soul-Winning-Ministry-100080165448656/",
    "https://www.youtube.com/@pastorreginalddublin3943/videos"
  ]
});

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "image": imageUrl,
  "description": description,
  "publisher": {
    "@type": "Organization",
    "name": "Outreach for the Unreached Soul Winning Ministry",
    "url": siteUrl
  },
  "url": canonicalStr,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalStr
  }
});
---

<!-- Basic SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={image.alt} />
<meta property="og:site_name" content="Outreach for the Unreached Soul Winning Ministry" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={image.alt} />

<!-- Church JSON-LD Schema -->
<Fragment set:html={`<script type="application/ld+json">${churchSchema}</script>`} />

<!-- Pastor JSON-LD Schema -->
<Fragment set:html={`<script type="application/ld+json">${pastorSchema}</script>`} />

<!-- Article Schema (sermon/blog pages only) -->
{type === "article" && (
  <Fragment set:html={`<script type="application/ld+json">${articleSchema}</script>`} />
)}