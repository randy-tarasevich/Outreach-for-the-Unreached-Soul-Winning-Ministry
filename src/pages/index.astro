---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/Sections/HeroSection.astro";
import SermonList from "../components/Sections/SermonList.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout>
  <HeroSection 
    title="Outreach for the Unreached Soul Winning Ministry"
    subtitle="Spreading the Gospel wherever you are — join us live every Sunday on Facebook and YouTube"
    backgroundImage="/uploads/hero-bg.webp"
    ctaText="Watch Live"
    ctaLink="/watch-live"
    secondaryCtaText="Watch Sermons"
    secondaryCtaLink="/sermons"
  />
  
  <!-- Live Stream CTA -->
  <section class="py-16 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Join Us Live Every Sunday</h2>
        <p class="text-xl text-gray-600 mb-10">
          No matter where you are in the world, you have a home here. Stream our Sunday service live on your platform of choice.
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
          <div class="bg-gray-50 p-8 rounded-lg shadow-sm border border-gray-100">
            <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-blue-100 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2">Facebook Live</h3>
            <p class="text-gray-600 mb-4">Watch and interact with our community in real time</p>
            <a 
              href="https://www.facebook.com/p/Outreach-For-The-Unreached-Soul-Winning-Ministry-100080165448656/" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-5 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors"
            >
              Watch on Facebook
            </a>
          </div>
          
          <div class="bg-gray-50 p-8 rounded-lg shadow-sm border border-gray-100">
            <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-red-100 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-red-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2">YouTube Live</h3>
            <p class="text-gray-600 mb-4">Watch live or catch up on past services anytime</p>
            <a 
              href="https://www.youtube.com/@pastorreginalddublin3943/videos" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-5 py-2 text-sm font-medium text-white bg-red-600 rounded-md hover:bg-red-700 transition-colors"
            >
              Watch on YouTube
            </a>
          </div>
        </div>

        <p class="text-gray-500 text-sm">
          Sunday Service — <span class="font-semibold text-gray-700">Every Sunday at [Service Time]</span>
        </p>
      </div>
    </div>
  </section>
  
  <!-- About Section -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Our Mission</h2>
        <p class="text-gray-700 mb-6 text-lg">
          Outreach for the Unreached Soul Winning Ministry exists to bring the Gospel to every corner of the world — no walls, no barriers, no borders. We are a Spirit-filled online ministry committed to reaching the lost and discipling believers wherever they are.
        </p>
        <p class="text-gray-700 mb-8 text-lg">
          Whether you're tuning in from across the street or across the globe, you are welcome here. Join our growing online community and experience the power of worship, the Word, and fellowship — from wherever life finds you.
        </p>
        <Button href="/about-us">
          Learn More About Us
        </Button>
      </div>
    </div>
  </section>

  <!-- Sermons Section -->
  <SermonList />
  
  <!-- Call to Action -->
  <section 
    class="py-20 bg-primary-800 text-white"
  >
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">Ready to Connect?</h2>
        <p class="text-xl mb-8 text-primary-100">
          We'd love to hear from you. Submit a prayer request, ask a question, or just say hello — our community is here for you.
        </p>
        
        <div class="flex flex-wrap justify-center gap-4">
          <Button href="/watch-live" variant="primary" size="lg">
            Watch Live
          </Button>
          
          <Button href="/contact" variant="outline" size="lg" class="bg-white/10 text-white border-white hover:bg-white hover:text-gray-900 backdrop-blur-sm">
            Contact Us
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>