---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout
  title="I'm New - Outreach for the Unreached Soul Winning Ministry"
  description="Everything you need to know about joining our online ministry for the first time — service times, what to expect on the stream, and how to connect."
>
  <PageHeader 
    title="I'm New Here" 
    subtitle="Welcome! We're glad you're joining us online."
    backgroundImage="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=1920&h=600&fit=crop&crop=center"
  />
  
  <!-- What to Expect -->
  <section class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">What to Expect</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Here's what you can expect when you tune in for the first time
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-primary-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Service Length</h3>
          <p class="text-gray-700">
            Our services typically last about 75 minutes, including worship, announcements, and the sermon.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-primary-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Worship Style</h3>
          <p class="text-gray-700">
            Our worship blends contemporary and traditional elements. We sing both modern worship songs and classic hymns.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-primary-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Teaching Style</h3>
          <p class="text-gray-700">
            Our messages are biblically-based, practical, and applicable to everyday life. We focus on how Scripture speaks to our current challenges.
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- What to Wear -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <img 
            src="https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=800&h=600&fit=crop&crop=center" 
            alt="Welcoming online worship" 
            class="rounded-lg shadow-lg object-cover w-full h-full"
          />
        </div>
        
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Watch from anywhere</h2>
          <p class="text-gray-700 mb-6 text-lg">
            Because we’re an online-only ministry, you can worship from your living room, your break room, or wherever you have a connection. Dress however you’re comfortable — we’re glad you’re with us.
          </p>
          <p class="text-gray-700 mb-6 text-lg">
            Grab a Bible, a notebook, or just press play. Our priority is that you encounter Jesus, not that you look a certain way on camera.
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Service Times -->
  <section class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Service Times</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Join us live on Facebook and YouTube — no travel required
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <h3 class="text-xl font-bold mb-3">Sunday worship</h3>
          <div class="mb-4">
            <p class="text-gray-700 mb-2">Live on Facebook &amp; YouTube</p>
            <p class="italic text-gray-500 mt-2">Check our social pages for the exact time each week.</p>
          </div>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <h3 class="text-xl font-bold mb-3">Tuesday Bible study</h3>
          <div class="mb-4">
            <p class="text-2xl font-bold text-primary-600 mb-2">6:30 PM</p>
            <p class="text-gray-600">Weekly Bible study streamed live on Facebook</p>
            <p class="italic text-gray-500 mt-2">Online only</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- For families -->
  <section id="kids" class="py-16 bg-gray-50">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">For families</h2>
          <p class="text-gray-700 mb-6 text-lg">
            We love families and know many watch together from home. There’s no drop-off nursery or separate kids’ wing — parents can pause, discuss, and pray with their children right where they are.
          </p>
          <ul class="space-y-4 mb-6">
            <li class="flex items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-600 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">
                <strong>Watch together:</strong> Services work well on a TV or tablet so everyone can participate.
              </span>
            </li>
            <li class="flex items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-600 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">
                <strong>Need resources?</strong> Reach out through our contact page — we’re happy to point you to age-appropriate tools.
              </span>
            </li>
          </ul>
          
          <Button href="/contact">
            Contact us
          </Button>
        </div>
        
        <div>
          <img 
            src="https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=800&h=600&fit=crop&crop=center" 
            alt="Children at our church" 
            class="rounded-lg shadow-lg object-cover w-full h-full"
          />
        </div>
      </div>
    </div>
  </section>
  
  <!-- Join online (no physical campus) -->
  <section id="location" class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Where we meet</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We are an online-only ministry — there is no street address or parking lot. Worship with us on Facebook and YouTube.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white p-8 rounded-lg shadow-sm text-center border border-gray-100">
          <h3 class="text-xl font-bold mb-3">Facebook</h3>
          <p class="text-gray-700 mb-6">Live services and community</p>
          <Button
            href="https://www.facebook.com/p/Outreach-For-The-Unreached-Soul-Winning-Ministry-100080165448656/"
            target="_blank"
            variant="primary"
          >
            Go to Facebook
          </Button>
        </div>
        <div class="bg-white p-8 rounded-lg shadow-sm text-center border border-gray-100">
          <h3 class="text-xl font-bold mb-3">YouTube</h3>
          <p class="text-gray-700 mb-6">Watch live or on demand</p>
          <Button href="https://www.youtube.com/@pastorreginalddublin3943/videos" target="_blank" variant="primary">
            Go to YouTube
          </Button>
        </div>
      </div>
      <p class="text-center text-gray-600 mt-8 max-w-2xl mx-auto">
        Need to talk to someone? Call <a href="tel:+18607050042" class="text-primary-600 hover:text-primary-700 font-medium">(860) 705-0042</a> or visit our <a href="/contact" class="text-primary-600 hover:text-primary-700 font-medium">contact page</a>.
      </p>
    </div>
  </section>
  
  <!-- FAQ Section -->
  <section id="faq" class="py-16 bg-gray-50">
  <div class="container">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Frequently Asked Questions</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Answers to common questions for first-time viewers
      </p>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="space-y-4">
        <details class="group bg-white p-6 rounded-lg shadow-sm">
          <summary class="flex justify-between items-center cursor-pointer">
            <h3 class="text-xl font-bold">Do I need an account to watch?</h3>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <p class="mt-4 text-gray-700">
            You can watch on YouTube without signing in. Facebook may prompt you to log in to comment or react, but you can often still view the stream in a browser. Use whichever platform works best for you.
          </p>
        </details>

        <details class="group bg-white p-6 rounded-lg shadow-sm">
          <summary class="flex justify-between items-center cursor-pointer">
            <h3 class="text-xl font-bold">Will I be singled out on camera?</h3>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <p class="mt-4 text-gray-700">
            No. You’re watching like everyone else from home. You’re welcome to use chat or comments if you’d like to say hello, but there’s no pressure to be on camera or introduce yourself.
          </p>
        </details>

        <details class="group bg-white p-6 rounded-lg shadow-sm">
          <summary class="flex justify-between items-center cursor-pointer">
            <h3 class="text-xl font-bold">Is there a physical church to visit?</h3>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <p class="mt-4 text-gray-700">
            No. We are intentionally online-only so people anywhere can join. Fellowship happens in the live chat, comments, and through reaching out on our contact page or social channels.
          </p>
        </details>

        <details class="group bg-white p-6 rounded-lg shadow-sm">
          <summary class="flex justify-between items-center cursor-pointer">
            <h3 class="text-xl font-bold">How can I give or get prayer?</h3>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <p class="mt-4 text-gray-700">
            Use the <a href="/contact" class="text-primary-600 hover:text-primary-700">contact form</a> or call <a href="tel:+18607050042" class="text-primary-600 hover:text-primary-700">(860) 705-0042</a>. Many people also share prayer requests during live streams when hosts invite it.
          </p>
        </details>

        <details class="group bg-white p-6 rounded-lg shadow-sm">
          <summary class="flex justify-between items-center cursor-pointer">
            <h3 class="text-xl font-bold">How do I stay connected during the week?</h3>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <p class="mt-4 text-gray-700">
            Follow us on Facebook and YouTube for updates, join Tuesday Bible study online, and explore <a href="/sermons" class="text-primary-600 hover:text-primary-700">past messages</a> anytime. We’re glad to help you take next steps through our <a href="/contact" class="text-primary-600 hover:text-primary-700">contact page</a>.
          </p>
        </details>
      </div>
    </div>
  </div>
</section>
  
  <!-- Plan Your Visit CTA -->
  <section id="volunteer" class="py-20 bg-cover bg-center text-white"
    style="background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(/uploads/visit-us.webp)"
  >
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">Ready to join us online?</h2>
        <p class="text-xl mb-8">
          We look forward to worshiping with you on the stream. If you have questions before you tune in, reach out — we’d love to hear from you.
        </p>
        
        <div class="flex flex-wrap justify-center gap-4">
          <Button href="/contact" variant="primary" size="lg">
            Contact Us
          </Button>
          
          <Button href="https://www.facebook.com/p/Outreach-For-The-Unreached-Soul-Winning-Ministry-100080165448656/" target="_blank" variant="outline" size="lg" class="bg-white/10 text-white border-white hover:bg-white hover:text-gray-900 backdrop-blur-sm">
            Watch live
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>